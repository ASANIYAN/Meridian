# Keep the build context lean and reproducible. The Dockerfile installs deps
# from the lockfile, so local node_modules and prior builds must not leak in.
node_modules
dist
coverage

# VCS + local tooling
.git
.gitignore
.vscode
.idea
.DS_Store

# Local env — never bake real secrets/URLs into an image layer. Pass VITE_* as
# build args and API_UPSTREAM at runtime instead.
.env
.env.local
.env.*.local

# Docs (not needed at build time)
*.md

# The image builds its own copies of these from the build context.
Dockerfile
.dockerignore
